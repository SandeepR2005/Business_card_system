{
  "name": "askeva-mobile",
  "version": "2.0.0",
  "description": "AskEva - Business Card Scanning App with LEADTOOLS On-Device OCR",
  "scripts": {
    "start": "expo start --clear",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "eject": "expo eject",
    "leadtools:setup": "echo 'LEADTOOLS Integration Setup - Follow OCR_SYSTEM_IMPLEMENTATION.md for details'"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^6.1.0",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.9.26",
    "axios": "^1.16.1",
    "expo": "^54.0.0",
    "expo-camera": "~17.0.10",
    "expo-file-system": "~19.0.22",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-base64": "^0.2.2",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@types/react": "~19.1.10",
    "@types/react-native": "~0.72.0",
    "babel-preset-expo": "~54.0.10",
    "typescript": "^5.3.0"
  },
  "leadtoolsInfo": {
    "description": "LEADTOOLS Business Card Recognition Engine integration",
    "status": "interface-ready",
    "installationRequired": "true",
    "packages": [
      {
        "name": "leadtools",
        "description": "Main LEADTOOLS SDK",
        "required": true,
        "version": "latest",
        "installCommand": "npm install leadtools"
      },
      {
        "name": "leadtools-rasterio",
        "description": "Image I/O support",
        "required": true,
        "installCommand": "npm install leadtools-rasterio"
      },
      {
        "name": "leadtools-document-binarization",
        "description": "Document preprocessing",
        "required": false,
        "installCommand": "npm install leadtools-document-binarization"
      }
    ],
    "setupGuide": "See OCR_SYSTEM_IMPLEMENTATION.md",
    "integrationFile": "src/utils/leadtools-ocr.ts",
    "serviceFile": "src/utils/ocr.ts",
    "currentImplementation": "Placeholder interface ready for LEADTOOLS SDK integration"
  },
  "private": true
}
